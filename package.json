    "@aws-sdk/client-ssm": "3.1058.0",
    "@cucumber/cucumber": "12.9.0",
    "@cucumber/pretty-formatter": "3.3.0",
    "@govuk-one-login/ipv-trust-and-reuse-eslint-rules": "1.0.5",
    "@pact-foundation/pact": "16.5.0",
    "@smithy/util-stream": "4.6.3",
    "@types/aws-lambda": "8.10.161",
    "@types/cfn-response-promise": "1.1.4",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/nunjucks": "3.2.6",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.19",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-vitest": "^7.0.1",
    "eslint": "10.4.0",
    "express": "5.2.1",
    "express-openapi-validator": "5.6.2",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "homepage": "https://github.com/govuk-one-login/ipv-identity-reuse-service#readme",
  "license": "MIT",
  "name": "ipv-identity-reuse-service",
  "overrides": {
    "@vitest/coverage-v8": "$vitest",
    "web-did-resolver": {
      "did-resolver": "$did-resolver"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/ipv-identity-reuse-service.git"
  },
  "scripts": {
    "detect-secrets:audit": "detect-secrets audit --json .secrets.baseline",
    "detect-secrets:scan": "detect-secrets scan --baseline .secrets.baseline",
    "lint": "eslint . --ext .ts --ignore-pattern **/coverage",
    "lint-fix": "eslint . --ext .ts --fix --ignore-pattern **/coverage",
    "test": "vitest --coverage",
    "test:acceptance": "cucumber-js",
    "test:consumer": "vitest --config src/tests/contract-tests/vitest.config.ts --project consumer",
    "test:provider": "vitest --config src/tests/contract-tests/vitest.config.ts --project provider",
    "test:unit": "test",
    "type-check": "tsc --noEmit"
  },
  "version": "0.0.1"
}
